# Copy to .env.local and fill in real values. NEVER commit .env.local.

# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend — email notifications (resend.com → API Keys)
RESEND_API_KEY=your-resend-key
RESEND_FROM=Saifi <onboarding@resend.dev>
# Public event submissions are emailed here. With onboarding@resend.dev this
# MUST be your Resend account's own email until you verify a custom domain.
ADMIN_EMAIL=you@example.com

# Public site URL — set to your production domain on Vercel
NEXT_PUBLIC_SITE_URL=http://localhost:3000
